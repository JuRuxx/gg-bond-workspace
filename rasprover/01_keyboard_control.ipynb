# 🚗 RaspRover 键盘遥控 🐷
# 在Jupyter里运行这个Cell，然后点击下面的输入框遥控小车！
# WASD = 前进/左/后退/右
# 方向键↑↓←→ = 云台上下左右
# 空格 = 急停 | Q = 退出

import sys, termios, tty, select, os, json, time

# --- 连上小车底盘 ---
# 树莓派5用 /dev/ttyAMA0，树莓派4B用 /dev/serial0
SERIAL_PORT = '/dev/ttyAMA0'
BAUD = 115200

import serial
ser = serial.Serial(SERIAL_PORT, BAUD, timeout=1)

def send_cmd(data):
    ser.write((json.dumps(data) + '\n').encode('utf-8'))

def getch():
    """非阻塞获取按键"""
    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        if select.select([sys.stdin], [], [], 0) == ([sys.stdin], [], []):
            ch = sys.stdin.read(1)
            return ch
        return None
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)

print("🐷 俺老猪来开车！")
print("━━━━━━━━━━━━━━━━━━━━━━━")
print("  WASD  →  开车")
print("  ↑↓←→  →  云台")
print("  空格  →  急停！")
print("  Q     →  退出")
print("━━━━━━━━━━━━━━━━━━━━━━━")
print("⚠️ 点一下这个Cell再按键盘！")
print("")

speed = 0       # 当前速度
turn = 0        # 当前转向
gimbal_x = 0    # 云台水平
gimbal_y = 0    # 云台垂直
running = True

try:
    while running:
        ch = getch()
        if ch:
            if ch.lower() == 'w':
                speed = min(speed + 20, 100)
                send_cmd({"T":1, "L":speed, "R":speed})
                print(f"🚗 前进  速度={speed}")
            elif ch.lower() == 's':
                speed = max(speed - 20, -100)
                send_cmd({"T":1, "L":speed, "R":speed})
                print(f"🚗 后退  速度={speed}")
            elif ch.lower() == 'a':
                turn = -40
                send_cmd({"T":1, "L":turn, "R":40})
                print(f"🚗 左转")
            elif ch.lower() == 'd':
                turn = 40
                send_cmd({"T":1, "L":40, "R":turn})
                print(f"🚗 右转")
            elif ch == ' ':  # 空格急停
                speed = 0
                turn = 0
                send_cmd({"T":1, "L":0, "R":0})
                print("🛑 急停！")
            elif ch == '\x1b':  # 方向键（以ESC [ A/B/C/D开头）
                ch2 = getch()
                ch3 = getch()
                if ch2 == '[':
                    if ch3 == 'A':     # ↑ 云台上
                        gimbal_y = min(gimbal_y + 10, 90)
                        send_cmd({"T":133, "X":gimbal_x, "Y":gimbal_y, "SPD":30, "ACC":10})
                        print(f"📷 云台上  Y={gimbal_y}")
                    elif ch3 == 'B':   # ↓ 云台下
                        gimbal_y = max(gimbal_y - 10, -30)
                        send_cmd({"T":133, "X":gimbal_x, "Y":gimbal_y, "SPD":30, "ACC":10})
                        print(f"📷 云台下  Y={gimbal_y}")
                    elif ch3 == 'C':   # → 云台右
                        gimbal_x = min(gimbal_x + 10, 180)
                        send_cmd({"T":133, "X":gimbal_x, "Y":gimbal_y, "SPD":30, "ACC":10})
                        print(f"📷 云台右  X={gimbal_x}")
                    elif ch3 == 'D':   # ← 云台左
                        gimbal_x = max(gimbal_x - 10, -180)
                        send_cmd({"T":133, "X":gimbal_x, "Y":gimbal_y, "SPD":30, "ACC":10})
                        print(f"📷 云台左  X={gimbal_x}")
            elif ch.lower() == 'q':
                print("👋 拜拜！")
                running = False
        
        time.sleep(0.05)

except KeyboardInterrupt:
    pass
finally:
    # 停车，云台回中
    send_cmd({"T":1, "L":0, "R":0})
    send_cmd({"T":133, "X":0, "Y":0, "SPD":30, "ACC":10})
    ser.close()
    print("✅ 已停车，安全！")
